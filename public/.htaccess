Options -MultiViews
RewriteEngine On
RewriteBase /

# Force HTTPS when TLS terminates at CDN / reverse proxy (prevents mixed-content redirects)
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,NE]

# BEGIN SPA_STATIC_TRAILING_SLASH
RewriteRule ^personal-area/attendance/attendance$ /personal-area/attendance/attendance/ [L]
RewriteRule ^personal-area/availability$ /personal-area/availability/ [L]
RewriteRule ^personal-area/attendance$ /personal-area/attendance/ [L]
RewriteRule ^personal-area/details$ /personal-area/details/ [L]
RewriteRule ^accounts/businesses$ /accounts/businesses/ [L]
RewriteRule ^company-employees$ /company-employees/ [L]
RewriteRule ^dashboards/leads$ /dashboards/leads/ [L]
RewriteRule ^jobs/exceptions$ /jobs/exceptions/ [L]
RewriteRule ^accounts/today$ /accounts/today/ [L]
RewriteRule ^tasks/my-tasks$ /tasks/my-tasks/ [L]
RewriteRule ^personal-area$ /personal-area/ [L]
RewriteRule ^tasks/urgent$ /tasks/urgent/ [L]
RewriteRule ^commissions$ /commissions/ [L]
RewriteRule ^jobs/search$ /jobs/search/ [L]
RewriteRule ^dashboards$ /dashboards/ [L]
RewriteRule ^jobs/leave$ /jobs/leave/ [L]
RewriteRule ^jobs/today$ /jobs/today/ [L]
RewriteRule ^tasks/done$ /tasks/done/ [L]
RewriteRule ^tasks/all$ /tasks/all/ [L]
RewriteRule ^accounts$ /accounts/ [L]
RewriteRule ^domains$ /domains/ [L]
RewriteRule ^tickets$ /tickets/ [L]
RewriteRule ^cities$ /cities/ [L]
RewriteRule ^leads$ /leads/ [L]
RewriteRule ^tasks$ /tasks/ [L]
RewriteRule ^jobs$ /jobs/ [L]
# END SPA_STATIC_TRAILING_SLASH

# Serve existing files and directories before SPA fallback
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback: route all other requests to index.html
RewriteRule ^(.*)$ /index.html [L,QSA]

# Fallback when rewrites are bypassed: still load SPA so client routes work on refresh
ErrorDocument 404 /index.html
